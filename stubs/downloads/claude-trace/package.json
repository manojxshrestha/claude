{
  "name": "@anthropic-ai/claude-trace",
  "version": "0.1.2",
  "description": "OTEL trace viewer for Claude Code sessions",
  "main": "dist/server.cjs",
  "type": "module",
  "bin": {
    "claude-trace": "./dist/server.cjs"
  },
  "files": [
    "dist/server.cjs",
    "viewer/dist/index.html",
    "viewer/dist/assets"
  ],
  "scripts": {
    "start": "node dist/server.cjs",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:viewer\"",
    "dev:server": "node --loader ts-node/esm --watch src/server.ts",
    "dev:viewer": "npm run dev --prefix viewer",
    "build": "npm run build:server && npm run build:viewer",
    "build:server": "esbuild src/server.ts --bundle --platform=node --format=cjs --minify --outfile=dist/server.cjs",
    "build:viewer": "npm run build --prefix viewer",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "body-parser": "^1.20.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.1",
    "express": "^4.18.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
