# =============================================================================
# Claude - Provider Configuration
# =============================================================================
# This file contains all environment variables for using free LLM providers
# instead of Anthropic's paid API.
#
# Copy this file to .env and configure your settings:
#   cp .env.example .env
# =============================================================================

# =============================================================================
# ENABLE FREE PROVIDER
# =============================================================================
# Set to true to enable free provider mode
USE_FREE_PROVIDER=false

# =============================================================================
# AUTHENTICATION (Optional)
# =============================================================================
# Set a token to protect your proxy from unauthorized access
# ANTHROPIC_AUTH_TOKEN="your-secret-token"

# =============================================================================
# NVIDIA NIM (40 req/min free, recommended)
# =============================================================================
# Get your API key from: https://build.nvidia.com/settings/api-keys
# NVIDIA_NIM_API_KEY="nvapi-your-key-here"

# Model mappings (provider/model-name format)
# MODEL_OPUS="nvidia_nim/z-ai/glm4.7"
# MODEL_SONNET="nvidia_nim/moonshotai/kimi-k2-thinking"
# MODEL_HAIKU="nvidia_nim/stepfun-ai/step-3.5-flash"
# MODEL="nvidia_nim/z-ai/glm4.7"

# Enable thinking models (kimi, nemotron). Leave false for others (e.g. Mistral)
# NIM_ENABLE_THINKING=true

# =============================================================================
# OPENROUTER (hundreds of models)
# =============================================================================
# Get your API key from: https://openrouter.ai/keys
# OPENROUTER_API_KEY="sk-or-your-key-here"

# Model mappings
# MODEL_OPUS="open_router/deepseek/deepseek-r1-0528:free"
# MODEL_SONNET="open_router/openai/gpt-oss-120b:free"
# MODEL_HAIKU="open_router/stepfun/step-3.5-flash:free"
# MODEL="open_router/stepfun/step-3.5-flash:free"

# =============================================================================
# LM STUDIO (fully local, no API key)
# =============================================================================
# Run LM Studio locally and load a model
# LM_STUDIO_BASE_URL="http://localhost:1234/v1"

# Model mappings (model IDs from LM Studio)
# MODEL_OPUS="lmstudio/unsloth/MiniMax-M2.5-GGUF"
# MODEL_SONNET="lmstudio/unsloth/Qwen3.5-35B-A3B-GGUF"
# MODEL_HAIKU="lmstudio/unsloth/GLM-4.7-Flash-GGUF"
# MODEL="lmstudio/unsloth/GLM-4.7-Flash-GGUF"

# =============================================================================
# LLAMA.CPP (fully local, no API key)
# =============================================================================
# Run llama-server locally: llama-server --port 8080
# LLAMACPP_BASE_URL="http://localhost:8080/v1"

# Model mappings
# MODEL_OPUS="llamacpp/local-model"
# MODEL_SONNET="llamacpp/local-model"
# MODEL_HAIKU="llamacpp/local-model"
# MODEL="llamacpp/local-model"

# =============================================================================
# MIX PROVIDERS
# =============================================================================
# You can use different providers for different model tiers:
# NVIDIA_NIM_API_KEY="nvapi-your-key-here"
# OPENROUTER_API_KEY="sk-or-your-key-here"

# MODEL_OPUS="nvidia_nim/moonshotai/kimi-k2.5"
# MODEL_SONNET="open_router/deepseek/deepseek-r1-0528:free"
# MODEL_HAIKU="open_router/stepfun/step-3.5-flash:free"
# MODEL="nvidia_nim/z-ai/glm4.7"

# =============================================================================
# RATE LIMITING (Optional)
# =============================================================================
# PROVIDER_RATE_LIMIT=40
# PROVIDER_RATE_WINDOW=60
# PROVIDER_MAX_CONCURRENCY=5

# =============================================================================
# HTTP TIMEOUTS (Optional)
# =============================================================================
# HTTP_READ_TIMEOUT=300
# HTTP_WRITE_TIMEOUT=10
# HTTP_CONNECT_TIMEOUT=2

# =============================================================================
# REQUEST OPTIMIZATIONS (Optional)
# =============================================================================
# These intercept trivial requests locally to save API quota:
# ENABLE_NETWORK_PROBE_MOCK=true
# ENABLE_TITLE_GENERATION_SKIP=true
# ENABLE_SUGGESTION_MODE_SKIP=true
# ENABLE_FILEPATH_EXTRACTION_MOCK=true
# FAST_PREFIX_DETECTION=true
